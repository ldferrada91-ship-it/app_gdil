<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;500;700&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: { extend: {
          fontFamily: { sans: ['Inter', 'sans-serif'] },
          colors: { clinblue: '#0284c7', clindark: '#0c4a6e', clinred: '#ef4444', clingreen: '#22c55e', clinamber: '#f59e0b' }
      }}
    }
  </script>
  <style>
    body { background-color: #f8fafc; font-family: 'Inter', sans-serif; display: flex; flex-direction: column; min-height: 100vh;}
    .glass-card { background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(12px); border: 1px solid #e2e8f0; border-radius: 1rem; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); }
    .btn-nav.active { color: #0284c7; border-bottom: 3px solid #0284c7; font-weight: 700; }
    .input-clin { width: 100%; border: 1px solid #cbd5e1; border-radius: 0.5rem; padding: 0.6rem 1rem; background: rgba(255,255,255,0.9); outline: none; font-size: 0.875rem; transition: all 0.2s; }
    .input-clin:focus { border-color: #0284c7; box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.1); }
    tbody tr:nth-child(even) { background-color: rgba(248, 250, 252, 0.6); }
    .loader { border: 3px solid #f3f3f3; border-top: 3px solid #0284c7; border-radius: 50%; width: 24px; height: 24px; animation: spin 1s linear infinite; }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
  </style>
</head>
<body class="text-slate-700">

  <div id="loginScreen" class="fixed inset-0 flex items-center justify-center bg-slate-900 bg-opacity-40 backdrop-blur-sm z-[100] transition-opacity duration-500">
    <div class="glass-card p-10 max-w-sm w-full mx-4 shadow-2xl relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-2 bg-clinblue"></div>
      <div class="text-center mb-8">
        <div class="inline-block bg-sky-100 p-3 rounded-full text-clinblue text-3xl mb-4"><i class="fas fa-microscope"></i></div>
        <h2 class="text-2xl font-bold text-clindark">GDIL Tracker</h2>
        <p class="text-xs text-slate-500 font-bold tracking-wider mt-1">Comité de gestión de la información de laboratorio - SSASUR</p>
      </div>
      <form id="formLogin" class="space-y-4">
        <div><label class="block text-xs font-bold text-slate-500 mb-1">RUN (Sin guion ni DV)</label><input type="number" id="loginRun" class="input-clin" required></div>
        <div><label class="block text-xs font-bold text-slate-500 mb-1">Clave</label><input type="password" id="loginPass" class="input-clin" required></div>
        <button type="submit" id="btnLogin" class="w-full bg-clinblue hover:bg-clindark text-white font-bold py-3 rounded-xl transition mt-6">Ingresar</button>
      </form>
      <div class="text-center mt-4">
        <button onclick="modalCambioClave()" class="text-[10px] text-slate-400 hover:text-clinblue underline"><i class="fas fa-key"></i> Cambiar mi contraseña</button>
      </div>
    </div>
  </div>

  <div id="mainApp" class="hidden flex-col flex-grow relative">
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-200">
      <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="bg-clinblue text-white p-2 rounded-xl"><i class="fas fa-network-wired"></i></div>
          <div><h1 class="font-bold text-clindark leading-tight">GDIL Tracker</h1></div>
        </div>
        <nav id="mainNav" class="flex gap-6 h-full items-end">
          <button onclick="tab('form')" id="btn-form" class="btn-nav active pb-4 text-sm font-medium">Registro</button>
          <button onclick="tab('hist')" id="btn-hist" class="btn-nav pb-4 text-sm font-medium">Historial</button>
          <button onclick="tab('data')" id="btn-data" class="btn-nav pb-4 text-sm font-medium admin-only hidden">Extracción</button>
          <button onclick="tab('conf')" id="btn-conf" class="btn-nav pb-4 text-sm font-medium admin-only hidden">Configuración</button>
        </nav>
        <div class="text-sm font-bold text-slate-500 flex items-center gap-3">
          <span><i class="fas fa-user-circle text-clinblue text-lg mr-1"></i> <span id="userNameDisplay"></span></span>
          <button onclick="modalCambioClave()" class="text-slate-400 hover:text-clinblue transition" title="Cambiar Contraseña"><i class="fas fa-key"></i></button>
          <button onclick="cerrarSesion()" class="bg-red-50 text-clinred hover:bg-red-100 px-3 py-1.5 rounded-lg text-xs font-bold transition" title="Cerrar Sesión"><i class="fas fa-sign-out-alt mr-1"></i>Salir</button>
        </div>
      </div>
    </header>

    <div id="alertsContainer" class="max-w-7xl mx-auto px-6 pt-4 flex flex-col gap-2 z-40"></div>

    <main class="flex-grow max-w-7xl mx-auto w-full px-6 py-8">
      
      <section id="sec-form" class="max-w-3xl mx-auto glass-card p-8 animate-fade-in">
        <h2 class="text-xl font-bold text-clindark mb-6"><i class="fas fa-file-medical text-clinblue mr-2"></i> Registro de nuevo caso</h2>
        <form id="formIncidencia" class="space-y-5">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            
            <div class="md:col-span-2">
              <label class="block text-xs font-bold text-slate-500 mb-1">TIPO DE CASO</label>
              <select name="tipo_caso" class="input-clin" required>
                <option value="">Seleccione el tipo de registro...</option>
                <option value="Solicitud">📋 Solicitud</option>
                <option value="Evento adverso">⚠️ Evento adverso</option>
                <option value="Sugerencia">💡 Sugerencia</option>
              </select>
            </div>

            <div><label class="block text-xs font-bold text-slate-500 mb-1">FASE LIS</label><select name="fase" id="sel-fase" class="input-clin" required></select></div>
            <div><label class="block text-xs font-bold text-slate-500 mb-1">PRIORIDAD</label>
              <select name="prioridad" class="input-clin" required><option value="Baja">🟢 Baja</option><option value="Media">🟡 Media</option><option value="Alta">🔴 Alta</option></select>
            </div>
            <div><label class="block text-xs font-bold text-slate-500 mb-1">LABORATORIO</label><select name="laboratorio" id="sel-lab" class="input-clin" required></select></div>
            <div><label class="block text-xs font-bold text-slate-500 mb-1">PROFESIONAL</label>
              <select name="usuario_nombre" id="sel-user" class="input-clin bg-slate-50" onchange="document.getElementById('hdn-email').value = this.options[this.selectedIndex].dataset.email" required></select>
              <input type="hidden" name="usuario_email" id="hdn-email">
            </div>
            <div><label class="block text-xs font-bold text-slate-500 mb-1">FECHA</label><input type="date" name="fecha" id="inp-fecha" class="input-clin" required></div>
            <div><label class="block text-xs font-bold text-slate-500 mb-1">HORA</label><input type="time" name="hora" id="inp-hora" class="input-clin" required></div>
          </div>
          
          <div>
            <label class="flex items-center text-xs font-bold text-slate-500 mb-1">
              IMPACTO OPERATIVO
              <button type="button" onclick="mostrarGuiaImpacto()" class="ml-2 bg-blue-50 text-clinblue hover:bg-blue-100 px-2 py-0.5 rounded-full transition" title="Guía para clasificar el impacto">
                <i class="fas fa-question-circle text-[10px]"></i> Ayuda
              </button>
            </label>
            <select name="impacto" id="sel-imp" class="input-clin" required></select>
          </div>

          <div><label class="block text-xs font-bold text-slate-500 mb-1">DESCRIPCIÓN</label>
            <textarea name="descripcion" rows="4" class="input-clin resize-none" placeholder="Detalle del problema o sugerencia..." required></textarea>
          </div>
          <button type="submit" id="btn-submit" class="w-full bg-clinblue hover:bg-clindark text-white font-bold py-3 rounded-xl transition flex justify-center items-center gap-2">
            <i class="fas fa-paper-plane"></i> Registrar evento
          </button>
        </form>
      </section>

      <section id="sec-hist" class="hidden space-y-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
           <div class="glass-card p-4 border-l-4 border-clinblue shadow-sm">
              <p class="text-[10px] uppercase font-bold text-slate-400">Registrados Hoy</p><h3 id="m-hoy" class="text-2xl font-bold text-clindark">0</h3>
           </div>
           <div class="glass-card p-4 border-l-4 border-clinred shadow-sm">
              <p class="text-[10px] uppercase font-bold text-slate-400">SLA Vencido</p><h3 id="m-atr" class="text-2xl font-bold text-clinred">0</h3>
           </div>
           <div class="glass-card p-4 border-l-4 border-clingreen shadow-sm">
              <p class="text-[10px] uppercase font-bold text-slate-400">Finalizados</p><h3 id="m-fin" class="text-2xl font-bold text-clingreen">0</h3>
           </div>
           <div class="glass-card p-4 border-l-4 border-clinamber shadow-sm">
              <p class="text-[10px] uppercase font-bold text-slate-400">Laboratorio (+ Casos)</p><h3 id="m-lab" class="text-sm font-bold text-clindark truncate mt-1">N/A</h3>
           </div>
        </div>

        <div class="glass-card p-4">
          <div class="grid grid-cols-1 md:grid-cols-4 lg:grid-cols-8 gap-3 items-end">
             <div class="lg:col-span-2 relative">
                <i class="fas fa-search absolute left-3 top-2.5 text-slate-400"></i>
                <input type="text" id="f-busq" placeholder="Buscar ID o tipo..." class="input-clin pl-9 py-1.5" onkeyup="aplicarFiltrosHistorial()">
             </div>
             <div class="relative">
                <input type="date" id="f-fecha" class="input-clin py-1.5 text-xs" onchange="aplicarFiltrosHistorial()" title="Filtrar por Fecha">
             </div>
             <select id="f-lab" class="input-clin py-1.5 text-xs" onchange="aplicarFiltrosHistorial()"></select>
             <select id="f-fase" class="input-clin py-1.5 text-xs" onchange="aplicarFiltrosHistorial()"></select>
             <select id="f-estado" class="input-clin py-1.5 text-xs" onchange="aplicarFiltrosHistorial()">
                <option value="">Estado (Todos)</option><option>Recepcionado</option><option>En revisión</option><option>Postergado</option><option>Finalizado</option>
             </select>
             <select id="f-pri" class="input-clin py-1.5 text-xs" onchange="aplicarFiltrosHistorial()">
                <option value="">Prioridad</option><option>Alta</option><option>Media</option><option>Baja</option>
             </select>
             <button onclick="loadHist()" class="bg-slate-100 hover:bg-slate-200 text-clindark rounded-lg py-1.5 text-xs font-bold transition whitespace-nowrap"><i class="fas fa-sync-alt mr-1"></i> Refrescar</button>
          </div>
        </div>

        <div class="glass-card overflow-hidden">
          <div class="flex justify-between items-center bg-slate-50 p-3 border-b border-slate-200">
            <h2 class="text-sm font-bold text-clindark"><i class="fas fa-list text-clinblue mr-2"></i> Historial de casos</h2>
            <select id="sel-limite" class="border p-1 rounded text-xs outline-none bg-white" onchange="currentPage=1; renderTablaHistorial()">
              <option value="10">10 por pág.</option><option value="20">20 por pág.</option><option value="30">30 por pág.</option>
            </select>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-left text-xs whitespace-nowrap">
              <thead class="bg-white text-slate-500 uppercase tracking-wider font-bold border-b border-slate-200">
                <tr>
                  <th class="p-3">ID Caso</th>
                  <th class="p-3">Fecha</th>
                  <th class="p-3">Tipo / Prioridad</th>
                  <th class="p-3">Lab / Fase</th>
                  <th class="p-3">SLA</th>
                  <th class="p-3">Revisor</th>
                  <th class="p-3">Estado</th>
                  <th class="p-3 text-right">Acciones</th>
                </tr>
              </thead>
              <tbody id="tb-hist" class="divide-y divide-slate-100 font-medium"></tbody>
            </table>
          </div>
          <div class="bg-slate-50 p-3 flex justify-between items-center text-xs font-bold border-t border-slate-200">
             <button onclick="paginar(-1)" class="text-clinblue hover:text-clindark px-3 py-1 rounded hover:bg-blue-50 transition"><i class="fas fa-chevron-left mr-1"></i> Anterior</button>
             <span id="txt-paginacion" class="text-slate-500">Pág. 1</span>
             <button onclick="paginar(1)" class="text-clinblue hover:text-clindark px-3 py-1 rounded hover:bg-blue-50 transition">Siguiente <i class="fas fa-chevron-right ml-1"></i></button>
          </div>
        </div>
      </section>

      <section id="sec-data" class="hidden glass-card p-8 max-w-4xl mx-auto">
        <h2 class="text-xl font-bold text-clindark mb-6 border-b pb-2"><i class="fas fa-file-excel text-clingreen mr-2"></i> Extracción de Datos</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
           <div><label class="block text-xs font-bold text-slate-500 mb-1">FECHA INICIO</label><input type="date" id="ex-ini" class="input-clin"></div>
           <div><label class="block text-xs font-bold text-slate-500 mb-1">FECHA FIN</label><input type="date" id="ex-fin" class="input-clin"></div>
           <div><label class="block text-xs font-bold text-slate-500 mb-1">LABORATORIO</label><select id="ex-lab" class="input-clin"></select></div>
           <div><label class="block text-xs font-bold text-slate-500 mb-1">FASE LIS</label><select id="ex-fase" class="input-clin"></select></div>
        </div>
        <button onclick="exportarExcelConFiltros()" class="bg-clingreen hover:bg-green-600 text-white font-bold py-3 px-8 rounded-xl w-full md:w-auto shadow-md transition"><i class="fas fa-download mr-2"></i>Descargar CSV</button>
      </section>

      <section id="sec-conf" class="hidden glass-card p-8 max-w-4xl mx-auto">
        <div class="flex items-center gap-3 border-b pb-4 mb-6">
          <i class="fas fa-cogs text-clinblue text-2xl"></i>
          <div><h2 class="text-xl font-bold text-clindark">Mantenedor de base de datos</h2><p class="text-xs text-slate-500">Agrega, edita y ordena variables del sistema</p></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="md:col-span-1 border-r pr-6">
            <label class="block text-xs font-bold text-slate-500 mb-2">SELECCIONE CATEGORÍA</label>
            <div class="flex flex-col gap-2">
              <button onclick="selConfigType('Laboratorio')" id="btn-cat-Laboratorio" class="cat-btn text-left px-4 py-2 rounded-lg text-sm transition bg-slate-100 text-clindark font-bold">Laboratorios</button>
              <button onclick="selConfigType('Fase')" id="btn-cat-Fase" class="cat-btn text-left px-4 py-2 rounded-lg text-sm transition hover:bg-slate-50 text-slate-600">Fases LIS</button>
              <button onclick="selConfigType('Impacto')" id="btn-cat-Impacto" class="cat-btn text-left px-4 py-2 rounded-lg text-sm transition hover:bg-slate-50 text-slate-600">Impactos</button>
              <button onclick="selConfigType('Usuario')" id="btn-cat-Usuario" class="cat-btn text-left px-4 py-2 rounded-lg text-sm transition hover:bg-slate-50 text-slate-600">Usuarios</button>
            </div>
          </div>
          <div class="md:col-span-2">
            <div id="conf-form-area" class="bg-slate-50 p-4 rounded-xl border border-slate-200 mb-6"></div>
            <div class="overflow-y-auto max-h-64 border border-slate-200 rounded-xl">
              <table class="w-full text-left text-xs"><thead class="bg-slate-100 text-slate-500 sticky top-0"><tr id="conf-th"></tr></thead><tbody id="conf-tb" class="divide-y divide-slate-100"></tbody></table>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="text-center text-[10px] text-slate-400 py-6 mt-auto">
      Aplicación desarrollada por TM Luis Ferrada Toro, GDIL SSASUR, v 0.6b, 2026
    </footer>
  </div>

  <script>
    let sessionUser = null; 
    let historicoDataOriginal = []; 
    let historicoDataFiltrado = []; 
    let currentPage = 1;
    let configLists = {};

    document.getElementById('formLogin').onsubmit = function(e) {
      e.preventDefault();
      const btn = document.getElementById('btnLogin'); btn.innerHTML = '<div class="loader mx-auto"></div>'; btn.disabled = true;
      google.script.run
        .withSuccessHandler(res => {
          if(res.success) iniciarApp(res);
          else { Swal.fire('Error', res.message, 'error'); btn.innerHTML = 'Ingresar'; btn.disabled = false; }
        })
        .withFailureHandler(err => { Swal.fire('Error', err.message, 'error'); btn.innerHTML = 'Ingresar'; btn.disabled = false; })
        .validarLogin(document.getElementById('loginRun').value, document.getElementById('loginPass').value);
    };

    function iniciarApp(res) {
      sessionUser = res.user; 
      configLists = res.config;
      document.getElementById('loginScreen').classList.add('hidden');
      document.getElementById('mainApp').classList.remove('hidden'); document.getElementById('mainApp').classList.add('flex');
      document.getElementById('userNameDisplay').innerText = sessionUser.nombre;

      if (sessionUser.rol === 'Admin') {
        document.querySelectorAll('.admin-only').forEach(el => el.classList.remove('hidden'));
        loadConfigData(); 
      }

      const now = new Date(); document.getElementById('inp-fecha').valueAsDate = now; document.getElementById('inp-hora').value = now.toTimeString().substring(0, 5);

      const fillSel = (id, arr, def) => document.getElementById(id).innerHTML = `<option value="">${def}</option>` + arr.map(i=>`<option>${i}</option>`).join('');
      fillSel('sel-fase', res.config.fases, 'Seleccione...'); fillSel('sel-imp', res.config.impactos, 'Seleccione...'); 
      fillSel('ex-fase', res.config.fases, 'Cualquier Fase'); fillSel('ex-lab', res.config.laboratorios, 'Cualquier Lab');
      fillSel('f-fase', res.config.fases, 'Fase (Todas)'); fillSel('f-lab', res.config.laboratorios, 'Lab (Todos)');

      const selLab = document.getElementById('sel-lab');
      selLab.innerHTML = '<option value="">Seleccione...</option>' + res.config.laboratorios.map(l=>`<option ${l === sessionUser.laboratorio ? 'selected' : ''}>${l}</option>`).join('');
      
      const uEl = document.getElementById('sel-user');
      uEl.innerHTML = res.usuariosDisponibles.map(u => `<option data-email="${u.email}" ${u.nombre === sessionUser.nombre ? 'selected' : ''}>${u.nombre}</option>`).join('');
      document.getElementById('hdn-email').value = sessionUser.email;
      if(sessionUser.rol !== 'Admin') uEl.disabled = true; 
    }

    function cerrarSesion() {
      sessionUser = null; historicoDataOriginal = []; historicoDataFiltrado = [];
      document.getElementById('formLogin').reset();
      document.getElementById('mainApp').classList.add('hidden'); document.getElementById('mainApp').classList.remove('flex');
      document.getElementById('loginScreen').classList.remove('hidden');
      tab('form');
    }

    function mostrarGuiaImpacto() {
      Swal.fire({
        title: '<div class="text-clindark text-lg border-b pb-2 flex items-center gap-2"><i class="fas fa-shield-alt text-clinblue"></i> Matriz de severidad</div>',
        html: `
          <div class="text-left text-sm space-y-3 mt-4 font-sans">
            <div class="p-3 bg-slate-50 border-l-4 border-slate-400 rounded shadow-sm hover:shadow-md transition">
              <p class="font-bold text-slate-700"><i class="fas fa-info-circle mr-1 text-slate-400"></i> I. Mínimo</p>
              <p class="text-xs text-slate-500 mt-1 ml-5">Error estético o sin afectación al flujo de trabajo del laboratorio.</p>
            </div>
            <div class="p-3 bg-blue-50 border-l-4 border-clinblue rounded shadow-sm hover:shadow-md transition">
              <p class="font-bold text-clindark"><i class="fas fa-wrench mr-1 text-clinblue"></i> II. Menor</p>
              <p class="text-xs text-slate-600 mt-1 ml-5">Afectación menor al flujo de trabajo. Requiere corrección.</p>
            </div>
            <div class="p-3 bg-amber-50 border-l-4 border-clinamber rounded shadow-sm hover:shadow-md transition">
              <p class="font-bold text-amber-900"><i class="fas fa-exclamation-triangle mr-1 text-clinamber"></i> III. Moderado</p>
              <p class="text-xs text-amber-700 mt-1 ml-5">Detención parcial de un área técnica. Afecta el normal funcionamiento del laboratorio.</p>
            </div>
            <div class="p-3 bg-orange-50 border-l-4 border-orange-500 rounded shadow-sm hover:shadow-md transition">
              <p class="font-bold text-orange-900"><i class="fas fa-minus-circle mr-1 text-orange-500"></i> IV. Mayor</p>
              <p class="text-xs text-orange-700 mt-1 ml-5">Detención total de la interfaz o de un proceso del laboratorio. Afecta a toda la red SSASUR. Riesgo clínico latente.</p>
            </div>
            <div class="p-3 bg-red-50 border-l-4 border-clinred rounded shadow-sm hover:shadow-md transition">
              <p class="font-bold text-red-900"><i class="fas fa-radiation-alt mr-1 text-clinred"></i> V. Crítico</p>
              <p class="text-xs text-red-700 mt-1 ml-5">Pérdida de integridad de datos, detención total de un proceso o generación de información incorrecta.</p>
            </div>
          </div>
        `,
        width: '550px',
        confirmButtonColor: '#0c4a6e',
        confirmButtonText: 'Entendido'
      });
    }

    function modalCambioClave() {
      Swal.fire({
        title: 'Cambiar Contraseña',
        html: `<input type="number" id="cl-run" class="swal2-input text-sm" placeholder="Su RUN (Sin guion)" value="${sessionUser?sessionUser.run:''}">
               <input type="password" id="cl-act" class="swal2-input text-sm" placeholder="Contraseña actual">
               <input type="password" id="cl-nue" class="swal2-input text-sm" placeholder="Nueva contraseña">`,
        confirmButtonText: 'Actualizar', confirmButtonColor: '#0284c7', showCancelButton: true,
        preConfirm: () => {
          const run = Swal.getPopup().querySelector('#cl-run').value; const act = Swal.getPopup().querySelector('#cl-act').value; const nue = Swal.getPopup().querySelector('#cl-nue').value;
          if (!run || !act || !nue) Swal.showValidationMessage('Todos los campos son obligatorios');
          return { run: run, act: act, nue: nue };
        }
      }).then((result) => {
        if (result.isConfirmed) {
          Swal.fire({title:'Actualizando...', didOpen:()=>{Swal.showLoading()}});
          google.script.run.withSuccessHandler(res => {
            if(res.success) Swal.fire('Éxito', res.message, 'success'); else Swal.fire('Error', res.message, 'error');
          }).cambiarClave(result.value.run, result.value.act, result.value.nue);
        }
      });
    }

    function tab(id) {
      document.querySelectorAll('main > section').forEach(s => s.classList.add('hidden'));
      document.querySelectorAll('.btn-nav').forEach(b => b.classList.remove('active'));
      document.getElementById('sec-' + id).classList.remove('hidden');
      document.getElementById('btn-' + id).classList.add('active');
      if (id === 'hist') loadHist(); 
    }

    document.getElementById('formIncidencia').onsubmit = function(e) {
      e.preventDefault();
      document.getElementById('sel-user').disabled = false; document.getElementById('sel-lab').disabled = false;
      const formData = Object.fromEntries(new FormData(this));
      if(sessionUser.rol !== 'Admin') { document.getElementById('sel-user').disabled = true; }

      const btn = document.getElementById('btn-submit'); btn.innerHTML = '<div class="loader mr-2"></div>...'; btn.disabled = true;
      google.script.run.withSuccessHandler(res => {
        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Registrado ID: '+res.id, showConfirmButton: false, timer: 3000 });
        this.reset();
        const now = new Date(); document.getElementById('inp-fecha').valueAsDate = now; document.getElementById('inp-hora').value = now.toTimeString().substring(0, 5);
        document.getElementById('sel-lab').value = sessionUser.laboratorio;
        const uEl = document.getElementById('sel-user'); Array.from(uEl.options).forEach((opt, idx) => { if(opt.text === sessionUser.nombre) uEl.selectedIndex = idx; });
        btn.innerHTML = '<i class="fas fa-paper-plane"></i> Registrar Evento'; btn.disabled = false;
      }).registrarCaso(formData, sessionUser);
    };

    function loadHist() {
      document.getElementById('tb-hist').innerHTML = '<tr><td colspan="8" class="text-center py-6 text-slate-500"><i class="fas fa-circle-notch fa-spin text-clinblue text-lg"></i><br>Cargando datos...</td></tr>';
      google.script.run.withSuccessHandler(res => {
        document.getElementById('m-hoy').innerText = res.metrics.hoy; document.getElementById('m-atr').innerText = res.metrics.atrasados;
        document.getElementById('m-fin').innerText = res.metrics.finalizados; document.getElementById('m-lab').innerText = res.metrics.labMax;
        historicoDataOriginal = res.casos;
        aplicarFiltrosHistorial(); 
      }).getCasos(sessionUser);
    }

    function aplicarFiltrosHistorial() {
      const q = document.getElementById('f-busq').value.toLowerCase(); const est = document.getElementById('f-estado').value;
      const pri = document.getElementById('f-pri').value; const lab = document.getElementById('f-lab').value; const fase = document.getElementById('f-fase').value;
      const fec = document.getElementById('f-fecha').value; 

      historicoDataFiltrado = historicoDataOriginal.filter(r => {
        const matchQ = !q || r.ID.toLowerCase().includes(q) || r.Laboratorio.toLowerCase().includes(q) || r.Descripcion.toLowerCase().includes(q) || r.Tipo_Caso.toLowerCase().includes(q);
        const matchEst = !est || r.Estado === est; const matchPri = !pri || r.Prioridad === pri;
        const matchLab = !lab || r.Laboratorio === lab; const matchFase = !fase || r.Fase === fase;
        
        let matchFec = true;
        if(fec && r.Fecha) {
           let p = r.Fecha.split('/');
           let rDateStr = `${p[2]}-${p[1]}-${p[0]}`; 
           matchFec = (rDateStr === fec);
        }
        return matchQ && matchEst && matchPri && matchLab && matchFase && matchFec;
      });
      currentPage = 1; renderTablaHistorial();
    }

    function renderTablaHistorial() {
      const tb = document.getElementById('tb-hist');
      if(historicoDataFiltrado.length === 0) { tb.innerHTML = '<tr><td colspan="8" class="text-center py-4 text-slate-500">No hay registros</td></tr>'; document.getElementById('txt-paginacion').innerText = `Pág. 0`; return; }
      
      const limit = parseInt(document.getElementById('sel-limite').value);
      const start = (currentPage - 1) * limit; const pagData = historicoDataFiltrado.slice(start, start + limit);
      document.getElementById('txt-paginacion').innerText = `Pág. ${currentPage} de ${Math.ceil(historicoDataFiltrado.length / limit)}`;

      tb.innerHTML = '';
      pagData.forEach(r => {
        let cp = r.Prioridad==='Alta'?'text-clinred font-bold':(r.Prioridad==='Media'?'text-clinamber':'text-clingreen');
        let cd = r.Dias_Estado >= 5 ? 'text-clinred font-bold' : 'text-slate-500';
        
        let acciones = `<button onclick='verData(${JSON.stringify(r).replace(/'/g,"&#39;")})' class="text-clinblue hover:text-clindark p-1" title="Info"><i class="fas fa-eye fa-lg"></i></button>`;
        acciones += `<button onclick="dlPDF('${r.ID}')" class="text-clinred hover:text-red-800 p-1 ml-1" title="Descargar PDF"><i class="fas fa-file-pdf fa-lg"></i></button>`;
        if(sessionUser.rol === 'Admin' && r.Estado !== 'Finalizado') {
          acciones += `<button onclick='modalFinalizar("${r.ID}")' class="text-clingreen hover:text-green-800 p-1 ml-1" title="Finalizar Caso"><i class="fas fa-check-circle fa-lg"></i></button>`;
        }

        // Combinamos Tipo y Prioridad para mantener el diseño limpio
        tb.innerHTML += `<tr>
          <td class="p-3 font-mono text-clinblue">${r.ID}</td>
          <td class="p-3">${r.Fecha}</td>
          <td class="p-3"><div>${r.Tipo_Caso}</div><div class="${cp} text-[10px]">${r.Prioridad}</div></td>
          <td class="p-3"><div>${r.Laboratorio}</div><div class="text-[10px] text-slate-400">${r.Fase}</div></td>
          <td class="p-3 ${cd}">${r.Dias_Estado} d</td>
          <td class="p-3 text-xs text-slate-500 font-bold">${r.Revisor || '-'}</td>
          <td class="p-3"><select onchange="updateEst('${r.ID}', this.value)" class="border rounded p-1 text-xs outline-none focus:border-clinblue" ${sessionUser.rol!=='Admin'?'disabled':''}>
            <option ${r.Estado==='Recepcionado'?'selected':''}>Recepcionado</option><option ${r.Estado==='En revisión'?'selected':''}>En revisión</option>
            <option ${r.Estado==='Postergado'?'selected':''}>Postergado</option><option ${r.Estado==='Finalizado'?'selected':''}>Finalizado</option>
          </select></td>
          <td class="p-3 text-right whitespace-nowrap">${acciones}</td>
        </tr>`;
      });
    }

    function paginar(dir) {
      const limit = parseInt(document.getElementById('sel-limite').value);
      const totalPages = Math.ceil(historicoDataFiltrado.length / limit);
      if(dir === 1 && currentPage < totalPages) { currentPage++; renderTablaHistorial(); }
      if(dir === -1 && currentPage > 1) { currentPage--; renderTablaHistorial(); }
    }

    function updateEst(id, val) { google.script.run.actualizarEstado(id, val, sessionUser); }
    
    function modalFinalizar(id) {
       Swal.fire({
         title: 'Finalizar Caso',
         html: `
           <div class="text-left text-sm mb-4 text-slate-600 bg-slate-50 p-3 rounded-lg border">
             <p><strong>ID Ticket:</strong> ${id}</p>
             <p><strong>Cerrado por:</strong> ${sessionUser.nombre} (Admin)</p>
           </div>
           <textarea id="txt-res" class="swal2-textarea text-sm w-full" placeholder="Ingrese el comentario técnico o resolución del caso..." rows="4" style="margin:0; width: 100%;"></textarea>
         `,
         confirmButtonText: '<i class="fas fa-paper-plane mr-1"></i> Finalizar y Enviar Reporte',
         confirmButtonColor: '#22c55e', showCancelButton: true, cancelButtonText: 'Cancelar',
         preConfirm: () => {
            const val = document.getElementById('txt-res').value;
            if(!val) Swal.showValidationMessage('Debe ingresar un comentario.');
            return val;
         }
       }).then((res) => {
         if(res.isConfirmed) {
            Swal.fire({title:'Cerrando Ticket y Generando PDF...', didOpen:()=>Swal.showLoading()});
            google.script.run.withSuccessHandler(exito => {
               if(exito) { Swal.fire('Finalizado', 'El caso fue cerrado exitosamente.', 'success'); loadHist(); } 
               else Swal.fire('Error', 'No se pudo finalizar el caso.', 'error');
            }).finalizarCaso(id, res.value, sessionUser);
         }
       });
    }

    function verData(r) {
      let extraInfo = '';
      if(r.Estado === 'Finalizado' && r.Comentario) {
         extraInfo = `<div class="mt-3 p-3 bg-green-50 border-l-4 border-green-500 text-green-800"><p class="font-bold text-xs">Resolución por ${r.AdminRes}:</p><p class="text-xs whitespace-pre-wrap">${r.Comentario}</p></div>`;
      }
      Swal.fire({
        title: `<div class="text-clinblue text-lg border-b pb-2"><i class="fas fa-info-circle"></i> Detalle ${r.ID}</div>`,
        html: `<div class="text-left text-sm space-y-2 text-slate-600 mt-4">
                 <p><strong>Tipo:</strong> ${r.Tipo_Caso}</p>
                 <p><strong>Fase/Lab:</strong> ${r.Fase} / ${r.Laboratorio}</p>
                 <p><strong>Notificador:</strong> ${r.Notificador}</p>
                 <p><strong>Revisor:</strong> ${r.Revisor || 'Pendiente de revisión'}</p>
                 <p><strong>Impacto:</strong> ${r.Impacto}</p>
                 <p class="font-bold border-t pt-2">Descripción:</p>
                 <div class="bg-slate-50 p-3 rounded border text-xs whitespace-pre-wrap">${r.Descripcion}</div>
                 ${extraInfo}
               </div>`,
        confirmButtonColor: '#0c4a6e', width: '500px'
      });
    }

    function dlPDF(id) {
      Swal.fire({title:'Generando Informe...', didOpen:()=>{Swal.showLoading()}});
      google.script.run.withSuccessHandler(b64 => {
        Swal.close(); let a = document.createElement("a"); a.href = "data:application/pdf;base64," + b64; a.download = `Reporte_${id}.pdf`; a.click();
      }).generarPDFIndividual(id, JSON.stringify(sessionUser));
    }
    
    function exportarExcelConFiltros() {
      if(historicoDataOriginal.length===0) return;
      const dIni = document.getElementById('ex-ini').value; const dFin = document.getElementById('ex-fin').value;
      const lab = document.getElementById('ex-lab').value; const fase = document.getElementById('ex-fase').value;
      let aExportar = historicoDataOriginal.filter(r => {
         let matchLab = !lab || r.Laboratorio === lab; let matchFase = !fase || r.Fase === fase;
         let matchFec = true;
         if(dIni || dFin) {
            let p = r.Fecha.split('/'); 
            if(p.length === 3) {
               let fDoc = new Date(p[2], p[1]-1, p[0]); 
               if(dIni) { let dI = dIni.split('-'); let i = new Date(dI[0], dI[1]-1, dI[2], 0,0,0); matchFec = matchFec && (fDoc >= i); }
               if(dFin) { let dF = dFin.split('-'); let f = new Date(dF[0], dF[1]-1, dF[2], 23,59,59); matchFec = matchFec && (fDoc <= f); }
            } else { matchFec = false; }
         }
         return matchLab && matchFase && matchFec;
      });
      if(aExportar.length === 0) return Swal.fire('Aviso', 'No hay datos en este rango.', 'info');
      let csvContent = "\uFEFF"; 
      let headers = Object.keys(aExportar[0]).join(';'); csvContent += headers + '\n';
      csvContent += aExportar.map(r => Object.values(r).map(v => `"${(v||'').toString().replace(/"/g, '""').replace(/\n/g, " ")}"`).join(';')).join('\n');
      let blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' }); let url = URL.createObjectURL(blob);
      let a = document.createElement('a'); a.href = url; a.download = 'Base_Datos_GDIL.csv'; a.click(); URL.revokeObjectURL(url);
    }

    let currentConfigData = null; let activeConfigType = 'Laboratorio';
    function loadConfigData() { google.script.run.withSuccessHandler(res => { currentConfigData = res; renderConfigUI(); }).obtenerDatosConfiguracion(); }
    function selConfigType(type) {
      activeConfigType = type; document.querySelectorAll('.cat-btn').forEach(b => { b.classList.remove('bg-slate-100', 'text-clindark', 'font-bold'); b.classList.add('hover:bg-slate-50', 'text-slate-600'); });
      const activeBtn = document.getElementById('btn-cat-' + type); activeBtn.classList.add('bg-slate-100', 'text-clindark', 'font-bold'); activeBtn.classList.remove('hover:bg-slate-50', 'text-slate-600');
      renderConfigUI();
    }
    
    function renderConfigUI() {
      if(!currentConfigData) return;
      const formArea = document.getElementById('conf-form-area'), th = document.getElementById('conf-th'), tb = document.getElementById('conf-tb');
      tb.innerHTML = '';
      if (activeConfigType === 'Usuario') {
        formArea.innerHTML = `<div class="grid grid-cols-2 gap-3 mb-3"><input type="number" id="new-run" placeholder="RUN" class="input-clin text-xs" required><input type="text" id="new-clave" placeholder="Clave" class="input-clin text-xs" required><input type="text" id="new-nombre" placeholder="Nombre" class="input-clin text-xs" required><select id="new-rol" class="input-clin text-xs"><option value="User">Usuario</option><option value="Admin">Admin</option></select><input type="email" id="new-email" placeholder="Email" class="input-clin text-xs"><select id="new-lab" class="input-clin text-xs"><option value="">Lab Asignado...</option>${configLists.laboratorios.map(l=>`<option>${l}</option>`).join('')}</select><button onclick="addConfigItem()" class="col-span-2 bg-clinblue text-white rounded-lg text-xs font-bold py-2"><i class="fas fa-plus"></i> Agregar Usuario</button></div>`;
        th.innerHTML = '<th class="p-2">RUN</th><th class="p-2">Nombre</th><th class="p-2">Rol</th><th class="p-2">Lab Asignado</th><th class="p-2 text-right">Acción</th>';
        currentConfigData.Usuario.forEach(u => tb.innerHTML += `<tr><td class="p-2">${u.run}</td><td class="p-2">${u.nombre}</td><td class="p-2">${u.rol}</td><td class="p-2">${u.laboratorio || 'N/A'}</td><td class="p-2 text-right"><button onclick="editUsuario('${u.run}', '${u.nombre}', '${u.rol}', '${u.laboratorio}')" class="text-clinamber hover:text-amber-600 px-1"><i class="fas fa-edit"></i></button><button onclick="delConfigItem('${u.run}')" class="text-clinred px-1"><i class="fas fa-trash"></i></button></td></tr>`);
      } else {
        formArea.innerHTML = `<div class="flex gap-3"><input type="text" id="new-valor" placeholder="Nombre..." class="input-clin text-xs w-full"><button onclick="addConfigItem()" class="bg-clinblue text-white rounded-lg text-xs font-bold px-4 whitespace-nowrap"><i class="fas fa-plus"></i> Agregar</button></div>`;
        th.innerHTML = `<th class="p-2">Nombre</th><th class="p-2 text-right">Orden / Acción</th>`;
        (currentConfigData[activeConfigType] || []).forEach(val => tb.innerHTML += `<tr><td class="p-2">${val}</td><td class="p-2 text-right"><button onclick="moveConfigItem('${val}', -1)" class="text-slate-400 hover:text-clinblue px-1"><i class="fas fa-arrow-up"></i></button><button onclick="moveConfigItem('${val}', 1)" class="text-slate-400 hover:text-clinblue px-1"><i class="fas fa-arrow-down"></i></button><button onclick="editConfigVal('${val}')" class="text-clinamber hover:text-amber-600 px-1"><i class="fas fa-edit"></i></button><button onclick="delConfigItem('${val}')" class="text-clinred px-1"><i class="fas fa-trash"></i></button></td></tr>`);
      }
    }

    function addConfigItem() {
      let data = {};
      if (activeConfigType === 'Usuario') {
        data = { run: document.getElementById('new-run').value, clave: document.getElementById('new-clave').value, nombre: document.getElementById('new-nombre').value, rol: document.getElementById('new-rol').value, email: document.getElementById('new-email').value, telefono: '', laboratorio: document.getElementById('new-lab').value };
        if(!data.run || !data.nombre || !data.clave) return Swal.fire('Aviso', 'Faltan datos obligatorios', 'warning');
      } else {
        data = { valor: document.getElementById('new-valor').value }; if(!data.valor) return Swal.fire('Aviso', 'Ingrese un nombre', 'warning');
      }
      document.getElementById('conf-form-area').style.opacity = '0.5';
      google.script.run.withSuccessHandler(res => {
        document.getElementById('conf-form-area').style.opacity = '1';
        if(res.success) { Swal.fire({toast:true, position:'top-end', icon:'success', title:'Agregado', showConfirmButton:false, timer:2000}); loadConfigData(); }
      }).gestionarConfig('AGREGAR', activeConfigType, data, sessionUser);
    }
    
    function delConfigItem(id) {
      if(!confirm('¿Eliminar registro?')) return;
      google.script.run.withSuccessHandler(res => {
        if(res.success) { Swal.fire({toast:true, position:'top-end', icon:'success', title:'Eliminado', showConfirmButton:false, timer:2000}); loadConfigData(); }
      }).gestionarConfig('ELIMINAR', activeConfigType, { id: id }, sessionUser);
    }

    function moveConfigItem(val, dir) { google.script.run.withSuccessHandler(res => { if(res.success) loadConfigData(); }).gestionarConfig('MOVER', activeConfigType, { id: val, dir: dir }, sessionUser); }

    function editConfigVal(oldVal) {
       Swal.fire({ title: 'Editar Nombre', input: 'text', inputValue: oldVal, showCancelButton: true, confirmButtonText: 'Guardar' }).then((res) => {
          if(res.isConfirmed && res.value) { google.script.run.withSuccessHandler(r => { if(r.success) loadConfigData(); }).gestionarConfig('EDITAR', activeConfigType, { id: oldVal, nuevo: res.value }, sessionUser); }
       });
    }

    function editUsuario(run, nombre, rol, lab) {
       Swal.fire({
          title: 'Editar Usuario',
          html: `<input id="eu-nom" class="swal2-input text-sm" value="${nombre}" placeholder="Nombre">
                 <select id="eu-rol" class="swal2-input text-sm"><option value="User" ${rol==='User'?'selected':''}>Usuario</option><option value="Admin" ${rol==='Admin'?'selected':''}>Admin</option></select>
                 <select id="eu-lab" class="swal2-input text-sm"><option value="">Lab Asignado...</option>${configLists.laboratorios.map(l=>`<option ${l===lab?'selected':''}>${l}</option>`).join('')}</select>`,
          showCancelButton: true, confirmButtonText: 'Guardar',
          preConfirm: () => { return { id: run, nombre: document.getElementById('eu-nom').value, rol: document.getElementById('eu-rol').value, laboratorio: document.getElementById('eu-lab').value }; }
       }).then((res) => {
          if(res.isConfirmed) { google.script.run.withSuccessHandler(r => { if(r.success) loadConfigData(); }).gestionarConfig('EDITAR', 'Usuario', res.value, sessionUser); }
       });
    }
  </script>
</body>
</html>
